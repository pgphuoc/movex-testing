{
  "name": "movex-e2e-tests",
  "version": "1.0.0",
  "description": "MoveX Automation E2E Tests - Playwright",
  "scripts": {
    "test": "npx playwright test",
    "test:vehicle": "npx playwright test specs/vehicle/",
    "test:bp": "npx playwright test specs/business-partner/",
    "test:admin-info": "npx playwright test specs/administrative-info/",
    "test:toll": "npx playwright test specs/toll-station/",
    "test:routing": "npx playwright test specs/routing/",
    "test:cost": "npx playwright test specs/cost-group/",
    "test:headed": "npx playwright test --headed",
    "test:ui": "npx playwright test --ui",
    "test:debug": "npx playwright test --debug",
    "report": "npx playwright show-report",
    "install:browsers": "npx playwright install chromium",
    "create:module": "bash create-module.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0"
  }
}
